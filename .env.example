# ─── AWS / S3 ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ragflow-documents
S3_PREFIX=raw/

# ─── Confluence ──────────────────────────────────────────
CONFLUENCE_URL=https://your-org.atlassian.net
CONFLUENCE_USERNAME=you@example.com
CONFLUENCE_API_TOKEN=your_token
CONFLUENCE_SPACES=ENG,PROD          # comma-separated space keys

# ─── Git ─────────────────────────────────────────────────
GIT_REPOS=https://github.com/org/repo1,https://github.com/org/repo2
GIT_BRANCH=main
GIT_FILE_EXTENSIONS=.py,.md,.rst,.txt

# ─── Chunking ────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=recursive          # recursive | semantic | sentence

# ─── Airflow ─────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
