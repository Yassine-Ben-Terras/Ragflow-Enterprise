# ─── Local paths ─────────────────────────────────────────
DATA_DIR=data
PDF_SOURCE_DIR=data/pdfs

# ─── Confluence ──────────────────────────────────────────
CONFLUENCE_URL=https://your-org.atlassian.net
CONFLUENCE_USERNAME=you@example.com
CONFLUENCE_API_TOKEN=your_token
CONFLUENCE_SPACES=ENG,PROD

# ─── Git ─────────────────────────────────────────────────
GIT_REPOS=https://github.com/org/repo1,https://github.com/org/repo2
GIT_BRANCH=main
GIT_FILE_EXTENSIONS=.py,.md,.rst,.txt

# ─── Chunking ────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=recursive

# ─── Embeddings ──────────────────────────────────────────
EMBEDDING_PROVIDER=openai          # openai | bge
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
BGE_MODEL_NAME=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=64

# ─── Vector store ────────────────────────────────────────
VECTOR_STORE=qdrant                # qdrant | pgvector
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=ragflow
PGVECTOR_DSN=postgresql://ragflow:ragflow@localhost:5432/ragflow

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── RAG Pipeline ────────────────────────────────────────
HYBRID_TOP_K=20
RERANK_TOP_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
