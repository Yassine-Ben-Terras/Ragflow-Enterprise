{
  "uid": "ragflow-overview",
  "title": "ragflow-enterprise — Overview",
  "tags": ["ragflow", "rag", "monitoring"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(ragflow_requests_total)",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(ragflow_requests_total{status='error'}[5m])) / sum(rate(ragflow_requests_total[5m]))",
        "legendFormat": "Error Rate"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0,   "color": "green" },
              { "value": 0.05,"color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Mean Faithfulness (RAGAs)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.5, sum(rate(ragflow_ragas_faithfulness_bucket[1h])) by (le))",
        "legendFormat": "P50 Faithfulness"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0,   "color": "red" },
              { "value": 0.6, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mean Answer Relevancy (RAGAs)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.5, sum(rate(ragflow_ragas_answer_relevancy_bucket[1h])) by (le))",
        "legendFormat": "P50 Relevancy"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0,   "color": "red" },
              { "value": 0.6, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "User Satisfaction Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(ragflow_feedback_total{rating='thumbs_up'}) / sum(ragflow_feedback_total)",
        "legendFormat": "Satisfaction"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0,   "color": "red" },
              { "value": 0.7, "color": "yellow" },
              { "value": 0.85,"color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "End-to-End Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ragflow_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ragflow_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ragflow_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Pipeline Stage Latencies (p50)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ragflow_retrieval_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "Retrieval"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ragflow_rerank_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "Rerank"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ragflow_llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "LLM"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "title": "Feedback Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "increase(ragflow_feedback_total{rating='thumbs_up'}[1h])",
          "legendFormat": "👍 Thumbs Up"
        },
        {
          "expr": "increase(ragflow_feedback_total{rating='thumbs_down'}[1h])",
          "legendFormat": "👎 Thumbs Down"
        }
      ]
    },
    {
      "id": 9,
      "title": "Retrieval Candidates Histogram",
      "type": "histogram",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [{
        "expr": "sum(rate(ragflow_candidates_retrieved_bucket[5m])) by (le)",
        "legendFormat": "candidates"
      }]
    }
  ]
}
