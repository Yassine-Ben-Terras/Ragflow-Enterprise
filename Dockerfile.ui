# ── Streamlit UI ──────────────────────────────────────────────────────────────
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit>=1.35 \
    requests>=2.31

COPY ui/streamlit/ ui/streamlit/

EXPOSE 8501

CMD ["streamlit", "run", "ui/streamlit/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
